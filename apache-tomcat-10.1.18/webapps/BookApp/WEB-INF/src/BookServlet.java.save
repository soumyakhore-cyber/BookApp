                "postgres.ysnlzqhxxfmragaxbzbs",
                "HK6VLOGS@12345"
            );

            // SQL Query
            String sql = "SELECT * FROM public.books WHERE title ILIKE ? OR author ILIKE ?";

            PreparedStatement ps = con.prepareStatement(sql);

            ps.setString(1, "%" + key + "%");
            ps.setString(2, "%" + key + "%");

            // Execute Query
            ResultSet rs = ps.executeQuery();

